generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model admins {
  id            BigInt          @id @default(autoincrement())
  fullname      String          @db.VarChar(255)
  email         String          @db.VarChar(255)
  password      String?         @db.VarChar(255)
  phone         String          @db.VarChar(255)
  role          String          @db.VarChar(255)
  created_at    DateTime?       @db.Timestamp(6)
  updated_at    DateTime?       @db.Timestamp(6)
  courses       courses[]
  note_generals note_generals[]
  note_privates note_privates[]
}

model class_rooms {
  id            BigInt          @id @default(autoincrement())
  course_id     BigInt
  schedule      String          @db.VarChar(255)
  start         DateTime        @db.Date
  created_at    DateTime?       @db.Timestamp(6)
  updated_at    DateTime?       @db.Timestamp(6)
  courses       courses         @relation(fields: [course_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "class_rooms_course_id_foreign")
  class_user    class_user[]
  note_generals note_generals[]

  @@index([course_id], map: "class_rooms_course_id_foreign")
}

model class_user {
  id          BigInt      @id @default(autoincrement())
  user_id     BigInt
  class_id    BigInt
  created_at  DateTime?   @db.Timestamp(6)
  updated_at  DateTime?   @db.Timestamp(6)
  class_rooms class_rooms @relation(fields: [class_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "class_user_class_id_foreign")
  users       users       @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "class_user_user_id_foreign")

  @@index([class_id], map: "class_user_class_id_foreign")
  @@index([user_id], map: "class_user_user_id_foreign")
}

model courses {
  id          BigInt        @id @default(autoincrement())
  admin_id    BigInt
  name        String        @db.VarChar(255)
  total_time  Int
  url_image   String        @db.VarChar(255)
  price       BigInt
  description String
  created_at  DateTime?     @db.Timestamp(6)
  updated_at  DateTime?     @db.Timestamp(6)
  class_rooms class_rooms[]
  admins      admins        @relation(fields: [admin_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "courses_admin_id_foreign")
  exams       exams[]
  lessons     lessons[]

  @@index([admin_id], map: "courses_admin_id_foreign")
}

model exams {
  id         BigInt      @id @default(autoincrement())
  course_id  BigInt
  name       String      @db.VarChar(255)
  total_time Int
  status     String?     @db.VarChar(255)
  created_at DateTime?   @db.Timestamp(6)
  updated_at DateTime?   @db.Timestamp(6)
  courses    courses     @relation(fields: [course_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "exams_course_id_foreign")
  questions  questions[]
  scores     scores[]

  @@index([course_id], map: "exams_course_id_foreign")
}

model failed_jobs {
  id         BigInt   @id @default(autoincrement())
  connection String
  queue      String
  payload    String
  exception  String
  failed_at  DateTime @default(now()) @db.Timestamp(6)
}

model lessons {
  id          BigInt    @id @default(autoincrement())
  course_id   BigInt
  title       String    @db.VarChar(255)
  description String    @db.VarChar(255)
  link_video  String
  created_at  DateTime? @db.Timestamp(6)
  updated_at  DateTime? @db.Timestamp(6)
  courses     courses   @relation(fields: [course_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "lessons_course_id_foreign")

  @@index([course_id], map: "lessons_course_id_foreign")
}

model migrations {
  id        Int    @id @default(autoincrement())
  migration String @db.VarChar(255)
  batch     Int
}

model note_generals {
  id          BigInt      @id @default(autoincrement())
  class_id    BigInt
  admin_id    BigInt
  title       String      @db.VarChar(255)
  content     String
  created_at  DateTime?   @db.Timestamp(6)
  updated_at  DateTime?   @db.Timestamp(6)
  admins      admins      @relation(fields: [admin_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "note_generals_admin_id_foreign")
  class_rooms class_rooms @relation(fields: [class_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "note_generals_class_id_foreign")

  @@index([admin_id], map: "note_generals_admin_id_foreign")
  @@index([class_id], map: "note_generals_class_id_foreign")
}

model note_privates {
  id         BigInt    @id @default(autoincrement())
  user_id    BigInt
  admin_id   BigInt
  title      String    @db.VarChar(255)
  content    String
  created_at DateTime? @db.Timestamp(6)
  updated_at DateTime? @db.Timestamp(6)
  admins     admins    @relation(fields: [admin_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "note_privates_admin_id_foreign")
  users      users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "note_privates_user_id_foreign")

  @@index([admin_id], map: "note_privates_admin_id_foreign")
  @@index([user_id], map: "note_privates_user_id_foreign")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model password_resets {
  email      String    @db.VarChar(255)
  token      String    @db.VarChar(255)
  created_at DateTime? @db.Timestamp(6)

  @@index([email], map: "password_resets_email_index")
  @@ignore
}

model questions {
  id           BigInt    @id @default(autoincrement())
  exam_id      BigInt
  name         String
  answer_1     String
  answer_2     String
  answer_3     String
  answer_4     String
  answer_right String
  level        String    @db.VarChar(255)
  created_at   DateTime? @db.Timestamp(6)
  updated_at   DateTime? @db.Timestamp(6)
  exams        exams     @relation(fields: [exam_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "questions_exam_id_foreign")

  @@index([exam_id], map: "questions_exam_id_foreign")
}

model scores {
  id         BigInt    @id @default(autoincrement())
  user_id    BigInt
  exam_id    BigInt
  score      Float
  created_at DateTime? @db.Timestamp(6)
  updated_at DateTime? @db.Timestamp(6)
  exams      exams     @relation(fields: [exam_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "scores_exam_id_foreign")
  users      users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "scores_user_id_foreign")

  @@index([exam_id], map: "scores_exam_id_foreign")
  @@index([user_id], map: "scores_user_id_foreign")
}

model users {
  id                BigInt          @id @default(autoincrement())
  fullname          String          @db.VarChar(255)
  email             String          @unique(map: "users_email_unique") @db.VarChar(255)
  phone             String          @db.VarChar(255)
  birthday          DateTime        @db.Date
  url_avatar        String          @db.VarChar(255)
  status            String          @db.VarChar(255)
  email_verified_at DateTime?       @db.Timestamp(6)
  password          String?         @db.VarChar(255)
  remember_token    String?         @db.VarChar(100)
  created_at        DateTime?       @db.Timestamp(6)
  updated_at        DateTime?       @db.Timestamp(6)
  class_user        class_user[]
  note_privates     note_privates[]
  scores            scores[]
}
